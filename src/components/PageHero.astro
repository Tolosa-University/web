---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
}
const { eyebrow, title, subtitle } = Astro.props;
---

<section class="page-hero">
  <div class="wrap">
    {eyebrow && <p class="page-eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    {subtitle && <p class="page-sub">{subtitle}</p>}
  </div>
</section>

<style>
  .page-hero {
    background: #fff;
    color: var(--ink);
    padding-block: 3.5rem 3rem;
    border-bottom: 1px solid var(--line);
  }
  .page-eyebrow {
    font-size: 0.8rem;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--gold-deep);
    font-weight: 700;
    margin: 0 0 0.9rem;
  }
  .page-hero h1 {
    color: var(--navy);
    font-size: clamp(2.1rem, 5vw, 3.2rem);
    margin: 0;
    max-width: 30ch;
  }
  .page-sub {
    color: var(--muted);
    font-size: 1.15rem;
    max-width: 46rem;
    margin: 1.1rem 0 0;
  }
</style>
