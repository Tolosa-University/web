---
import Monogram from './Monogram.astro';

const nav = [
  { href: '/', label: 'Inicio' },
  { href: '/grados/', label: 'Grados' },
  { href: '/masteres/', label: 'Másteres' },
  { href: '/profesorado/', label: 'Profesorado' },
  { href: '/investigacion/', label: 'Investigación' },
  { href: '/servicios/', label: 'Servicios' },
  { href: '/nosotros/', label: 'Nosotros' },
  { href: '/generador/', label: 'Genera tu título' },
];

// Ruta actual normalizada para marcar el enlace activo.
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isActive = (href: string) => {
  const clean = href.replace(/\/+$/, '') || '/';
  return clean === '/' ? path === '/' : path.startsWith(clean);
};
---

<header class="site-header">
  <div class="bar">
    <a href="/" class="brand" aria-label="Tolosa University — inicio">
      <Monogram size={44} />
      <span class="wordmark">
        <span class="name">Tolosa University</span>
        <span class="tag">Est. Pre-AI</span>
      </span>
    </a>

    <button type="button" id="nav-toggle" class="burger" aria-label="Abrir menú" aria-expanded="false" aria-controls="site-nav">
      <span></span><span></span><span></span>
    </button>

    <nav class="nav" id="site-nav" aria-label="Principal">
      {nav.map((item) => (
        <a href={item.href} class:list={['nav-link', { active: isActive(item.href) }]}>
          {item.label}
        </a>
      ))}
      <a href="/generador/" class="btn-apply">Genera tu título</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle') as HTMLButtonElement;
  const header = toggle.closest('.site-header') as HTMLElement;
  toggle.addEventListener('click', () => {
    const open = header.classList.toggle('nav-open');
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
  });
</script>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 50;
    background: var(--navy);
    border-bottom: 3px solid var(--gold);
    box-shadow: 0 2px 20px rgba(9, 16, 30, 0.25);
  }

  .bar {
    max-width: 74rem;
    margin-inline: auto;
    padding: 0.7rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    color: #fff;
  }

  .wordmark {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .name {
    font-family: var(--font-slab);
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: #fff;
  }

  .tag {
    font-size: 0.62rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--gold-light);
    margin-top: 0.28rem;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 1.05rem;
  }

  .nav-link {
    color: #dfe4ee;
    text-decoration: none;
    font-size: 0.92rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    padding: 0.3rem 0;
    position: relative;
    transition: color 0.15s ease;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -0.1rem;
    height: 2px;
    width: 0;
    background: var(--gold);
    transition: width 0.2s ease;
  }

  .nav-link:hover,
  .nav-link.active {
    color: #fff;
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }

  .btn-apply {
    background: var(--gold);
    color: var(--navy);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.5rem 1.05rem;
    border-radius: 4px;
    transition: background 0.15s ease, transform 0.15s ease;
  }

  .btn-apply:hover {
    background: var(--gold-light);
    transform: translateY(-1px);
  }

  .burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 0.4rem;
    background: none;
    border: 0;
  }

  .burger span {
    display: block;
    width: 26px;
    height: 2px;
    background: #fff;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  @media (max-width: 980px) {
    .burger {
      display: flex;
    }

    .nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: var(--navy);
      border-bottom: 3px solid var(--gold);
      padding: 0.5rem 1.25rem 1.25rem;
      max-height: 0;
      overflow: hidden;
      /* visibility saca los enlaces del orden de tabulación mientras el menú está cerrado */
      visibility: hidden;
      transition: max-height 0.28s ease, visibility 0.28s;
    }

    .site-header.nav-open .nav {
      max-height: 30rem;
      visibility: visible;
    }

    .nav-link {
      padding: 0.85rem 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .btn-apply {
      margin-top: 1rem;
      text-align: center;
    }

    .site-header.nav-open .burger span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    .site-header.nav-open .burger span:nth-child(2) {
      opacity: 0;
    }
    .site-header.nav-open .burger span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>
