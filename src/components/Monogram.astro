---
// Emblema TU de Tolosa University, reproducido en SVG para nitidez total.
interface Props {
  size?: number;
  ring?: boolean;
  class?: string;
}
const { size = 48, ring = true, class: className = '' } = Astro.props;
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 100 100"
  role="img"
  aria-label="Tolosa University"
  xmlns="http://www.w3.org/2000/svg"
>
  {ring && (
    <circle cx="50" cy="50" r="47" fill="var(--navy)" stroke="var(--gold)" stroke-width="2" />
  )}
  <!-- U en dorado -->
  <path
    d="M26 34 L40 34 L40 58 Q40 64 46 64 L54 64 Q60 64 60 58 L60 34 L74 34 L74 59 Q74 78 55 78 L45 78 Q26 78 26 59 Z"
    fill="var(--gold)"
  />
  <!-- T en blanco, encajada sobre la U -->
  <rect x="30" y="20" width="40" height="11" rx="1.5" fill="#ffffff" />
  <rect x="44.5" y="20" width="11" height="34" rx="1.5" fill="#ffffff" />
</svg>
