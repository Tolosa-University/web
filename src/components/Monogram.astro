---
// Emblema TU de Tolosa University en SVG, fiel a la marca:
// disco crema con aro dorado, T dorada de palo (slab) y U azul marino entrelazadas.
interface Props {
  size?: number;
  ring?: boolean;
  class?: string;
}
const { size = 48, ring = true, class: className = '' } = Astro.props;

const NAVY = '#17263f';
const GOLD = '#b8912f';
const CREAM = '#f7f2e6';
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 120 120"
  role="img"
  aria-label="Tolosa University"
  xmlns="http://www.w3.org/2000/svg"
>
  {ring && (
    <>
      <circle cx="60" cy="60" r="57" fill={CREAM} stroke={GOLD} stroke-width="3.5" />
      <circle cx="60" cy="60" r="51" fill="none" stroke={GOLD} stroke-width="1" opacity="0.55" />
    </>
  )}

  <g transform="translate(27,24.4) scale(0.66)">
    <!-- U (azul marino) -->
    <g fill={NAVY}>
      <rect x="0" y="34" width="33" height="9" />
      <rect x="67" y="34" width="33" height="9" />
      <rect x="2" y="34" width="27" height="68" />
      <rect x="71" y="34" width="27" height="68" />
      <rect x="2" y="79" width="96" height="23" />
    </g>
    <!-- T (dorada) -->
    <g fill={GOLD}>
      <rect x="8" y="3" width="84" height="17" />
      <rect x="8" y="20" width="9" height="6" />
      <rect x="83" y="20" width="9" height="6" />
      <rect x="38" y="20" width="24" height="55" />
      <rect x="33" y="64" width="34" height="11" />
    </g>
  </g>
</svg>
