---
import type { Programa } from '../data/oferta';
import { linkWikipedia } from '../utils/wikipedia';

type Props = Programa;
const { name, tag, duration, desc, salidas } = Astro.props;
---

<article class="degree">
  <div class="degree-head">
    <span class="degree-tag">{tag}</span>
    <span class="degree-dur">{duration}</span>
  </div>
  <h3>{name}</h3>
  <p set:html={linkWikipedia(desc)} />
  <p class="degree-salidas"><strong>Salidas:</strong> {salidas}</p>
</article>

<style>
  .degree {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 1.9rem;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }
  .degree:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 36px rgba(20, 36, 63, 0.1);
    border-color: var(--gold);
  }
  .degree-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.8rem;
  }
  .degree-tag {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--gold-deep);
  }
  .degree-dur {
    font-size: 0.8rem;
    color: var(--muted);
    background: var(--cream);
    padding: 0.15rem 0.6rem;
    border-radius: 20px;
    white-space: nowrap;
  }
  .degree h3 {
    margin: 0 0 0.7rem;
    font-size: 1.3rem;
  }
  .degree p {
    color: var(--muted);
    margin: 0 0 0.9rem;
  }
  .degree-salidas {
    font-size: 0.9rem;
    padding-top: 0.7rem;
    border-top: 1px dashed var(--line);
  }
  .degree-salidas strong {
    color: var(--navy);
  }
</style>
