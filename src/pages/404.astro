---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada — Tolosa University" description="Esta página no existe. Pero seguro que la respuesta sí." noindex>
  <section class="section error-page">
    <div class="wrap center">
      <p class="code">404</p>
      <h1>Esto no lo sabíamos</h1>
      <p class="lead">
        Y mira que sabemos de casi todo. La página que buscas no existe o cambió de sitio.
        Prueba a consultarlo en la fuente original.
      </p>
      <div class="actions">
        <a href="/" class="btn btn-primary">Volver al inicio</a>
        <a href="/grados/" class="btn btn-outline">Ver grados</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .error-page {
    padding-block: 6rem;
  }
  .center {
    text-align: center;
  }
  .code {
    font-family: var(--font-serif);
    font-weight: 800;
    font-size: clamp(4rem, 15vw, 8rem);
    color: var(--gold);
    line-height: 1;
    margin: 0;
  }
  .error-page h1 {
    margin: 0.5rem 0 1rem;
  }
  .lead {
    max-width: 34rem;
    margin: 0 auto 2rem;
  }
  .actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
