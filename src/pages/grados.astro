---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import DegreeCard from '../components/DegreeCard.astro';
import { grados, masteres } from '../data/oferta';

const masters = masteres.slice(0, 3).map((m) => m.name);

const gradosSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Grados de Tolosa University',
  itemListElement: grados.map((g, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Course',
      name: g.name,
      description: g.desc,
      provider: { '@id': new URL('/#organization', Astro.site).href },
      offers: { '@type': 'Offer', category: 'Grado universitario' },
      hasCourseInstance: {
        '@type': 'CourseInstance',
        courseMode: 'onsite',
        location: 'Tolosa, Gipuzkoa',
      },
    },
  })),
};
---

<Layout
  title="Grados universitarios — Tolosa University"
  description="Descubre los grados de Tolosa University: cultura general, cálculo mental, orientación sin GPS, memoria prodigiosa y más. Conocimiento humano, verificado a mano."
  schema={gradosSchema}
>
  <PageHero
    eyebrow="Oferta académica"
    title="Grados para quien quiere saberlo todo"
    subtitle="Ocho grados y varios másteres diseñados para formar mentes autónomas, curiosas y sorprendentemente útiles en cualquier conversación."
  />

  <section class="section">
    <div class="wrap">
      <div class="grid grid-2">
        {grados.map((g) => (
          <DegreeCard {...g} />
        ))}
      </div>
    </div>
  </section>

  <section class="section section--cream">
    <div class="wrap masters">
      <div class="section-head">
        <p class="eyebrow">Posgrado</p>
        <h2>Másteres oficiales</h2>
        <p>
          Para quienes ya lo saben casi todo y quieren rematar la faena. Incluido uno, muy
          concreto, para quienes prefieren saltarse el paso de saber.
        </p>
      </div>
      <ul class="master-list">
        <li class="master-star">
          Máster en Tertulianismo Profesional — opina de todo sin saber nada
        </li>
        {masters.map((m) => (
          <li>{m}</li>
        ))}
      </ul>
      <p class="masters-cta">
        <a href="/masteres/" class="btn btn-outline">Ver todos los másteres</a>
      </p>
    </div>
  </section>

  <section class="section section--navy">
    <div class="wrap center callout">
      <h2>¿No encuentras tu vocación?</h2>
      <p class="lead" style="color:#c3ccdb">Diseñamos itinerarios a medida. Si se puede saber, se puede estudiar aquí.</p>
      <a href="/admisiones/" class="btn btn-primary">Habla con admisiones</a>
    </div>
  </section>
</Layout>

<style>
  .master-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.75rem;
  }
  .master-list li {
    background: #fff;
    border: 1px solid var(--line);
    border-left: 4px solid var(--gold);
    border-radius: 6px;
    padding: 1rem 1.25rem;
    font-weight: 600;
    color: var(--navy);
  }
  .master-list .master-star {
    border-left-color: var(--navy);
    background: var(--navy);
    color: #fff;
  }
  .masters-cta {
    margin: 1.5rem 0 0;
  }

  .callout .lead {
    margin: 0.6rem auto 1.6rem;
  }
  .center {
    text-align: center;
  }
</style>
