---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import DegreeCard from '../components/DegreeCard.astro';
import { masteres as masters } from '../data/oferta';

const asignaturas = [
  { name: '«Yo lo que creo es que…»: Introducción al Opinar', ects: '12 ECTS' },
  { name: 'Interrupción Asertiva I y II', ects: '9 ECTS' },
  { name: 'Vehemencia Aplicada: subir el volumen cuando bajan los argumentos', ects: '6 ECTS' },
  { name: 'Lectura Diagonal de Titulares', ects: '6 ECTS' },
  { name: 'Pivote Temático: de la prima de riesgo a la crianza del bogavante sin pestañear', ects: '9 ECTS' },
  { name: 'Gestualidad de Plató: la ceja, el bolígrafo y el «déjame terminar»', ects: '6 ECTS' },
  { name: 'Geopolítica Exprés: opinar de siete conflictos con un solo mapa mental', ects: '6 ECTS' },
  { name: 'TFM: opinar del TFM de un compañero sin haberlo leído', ects: '6 ECTS' },
];

const masteresSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Másteres de Tolosa University',
  itemListElement: [
    {
      name: 'Máster en Tertulianismo Profesional',
      desc: 'El programa estrella: fórmate para opinar de macroeconomía, geopolítica, virología y fichajes de invierno en la misma frase, sin haber abierto un libro de ninguna de las cuatro cosas.',
    },
    ...masters.map((m) => ({ name: m.name, desc: m.desc })),
  ].map((m, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Course',
      name: m.name,
      description: m.desc,
      provider: { '@id': new URL('/#organization', Astro.site).href },
      offers: { '@type': 'Offer', category: 'Máster universitario' },
      hasCourseInstance: {
        '@type': 'CourseInstance',
        courseMode: 'onsite',
        location: 'Tolosa, Gipuzkoa',
      },
    },
  })),
};
---

<Layout
  title="Másteres y posgrados — Tolosa University"
  description="Posgrados de Tolosa University: del Máster en Tertulianismo Profesional (opina de todo sin saber nada) al Máster en Silencio Estratégico. Excelencia opinativa desde antes de la IA."
  schema={masteresSchema}
>
  <PageHero
    eyebrow="Posgrado"
    title="Másteres para rematar la faena"
    subtitle="Cuando el grado se queda corto, el posgrado de Tolosa University te lleva al siguiente nivel: opinar con criterio. O, en un caso muy concreto, sin él."
  />

  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">Programa estrella</p>
        <h2>Máster en Tertulianismo Profesional</h2>
        <p>
          El único programa de Tolosa University donde el conocimiento es opcional. Fórmate para
          opinar de macroeconomía, geopolítica, virología y fichajes de invierno
          <em>en la misma frase</em> y sin haber abierto un libro de ninguna de las cuatro cosas.
        </p>
      </div>

      <article class="featured">
        <div class="featured-main">
          <p class="featured-claim">«No sé nada del tema, pero lo voy a decir muy alto.»</p>
          <p>
            Mientras el resto de la universidad se empeña en saber las cosas antes de decirlas,
            este máster explora el camino inverso, avalado por décadas de televisión en horario de
            máxima audiencia. Nuestro claustro sigue debatiendo si el programa es una genialidad o
            una vergüenza institucional. El debate, cómo no, lo modera un alumno de segundo curso,
            que ya opina mejor que todos ellos juntos.
          </p>

          <h3>Plan de estudios</h3>
          <ul class="syllabus">
            {asignaturas.map((a) => (
              <li>
                <span>{a.name}</span>
                <span class="ects">{a.ects}</span>
              </li>
            ))}
          </ul>
          <p class="fine-print">
            * ECTS: Escala de Convicción Totalmente Subjetiva. La defensa del TFM es obligatoria;
            su lectura, opcional.
          </p>
        </div>

        <aside class="featured-side">
          <h3>Ficha del programa</h3>
          <dl>
            <dt>Duración</dt>
            <dd>1 año, que el alumno estirará hasta que le corten el micro.</dd>
            <dt>Modalidad</dt>
            <dd>Presencial. Un tertuliano sin público es solo alguien equivocado en voz baja.</dd>
            <dt>Requisitos de acceso</dt>
            <dd>
              No se exige titulación previa. De hecho, acreditar conocimientos sobre el temario
              puntúa negativamente.
            </dd>
            <dt>Criterio de evaluación</dt>
            <dd>Se aprueba por convicción, no por acierto. Empatar un debate es suspender.</dd>
            <dt>Salidas profesionales</dt>
            <dd>Tertuliano de prime time · Opinólogo todoterreno · Cuñado con título oficial</dd>
          </dl>
          <a href="/generador/" class="btn btn-primary">Solicitar plaza (sin pensarlo)</a>
        </aside>
      </article>
    </div>
  </section>

  <section class="section section--cream">
    <div class="wrap">
      <div class="section-head">
        <p class="eyebrow">Resto de la oferta</p>
        <h2>Másteres para quienes prefieren saber antes de hablar</h2>
        <p>
          El itinerario tradicional de la casa: primero se estudia, luego se opina. Anticuado,
          lo sabemos. Nos encanta.
        </p>
      </div>
      <div class="grid grid-2">
        {masters.map((m) => (
          <DegreeCard {...m} />
        ))}
      </div>
    </div>
  </section>

  <section class="section section--navy">
    <div class="wrap center callout">
      <h2>¿Dudas entre saber o parecer que sabes?</h2>
      <p class="lead" style="color:#c3ccdb">
        Nuestro equipo de admisiones te orientará. Y si no sabe la respuesta, te la dirá igualmente
        con muchísima seguridad.
      </p>
      <a href="/admisiones/" class="btn btn-primary">Habla con admisiones</a>
      <a href="/grados/" class="btn btn-ghost" style="margin-left:0.75rem">Ver los grados</a>
    </div>
  </section>
</Layout>

<style>
  .featured {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  .featured-main {
    background: #fff;
    border: 1px solid var(--line);
    border-top: 4px solid var(--gold);
    border-radius: 12px;
    padding: 2rem;
  }
  .featured-main p {
    color: var(--muted);
  }
  .featured-claim {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.35rem;
    color: var(--navy) !important;
    margin: 0 0 1rem;
  }
  .featured-main h3 {
    margin: 1.8rem 0 1rem;
    font-size: 1.2rem;
  }

  .syllabus {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.5rem;
  }
  .syllabus li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.6rem 0.9rem;
    background: var(--cream);
    border-left: 3px solid var(--gold);
    border-radius: 4px;
    font-size: 0.95rem;
  }
  .ects {
    white-space: nowrap;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--gold-deep);
    letter-spacing: 0.06em;
  }
  .fine-print {
    font-size: 0.82rem;
    margin: 1rem 0 0;
  }

  .featured-side {
    background: var(--navy);
    color: #dfe4ee;
    border-radius: 12px;
    padding: 1.9rem;
    position: sticky;
    top: 6rem;
  }
  .featured-side h3 {
    color: #fff;
    margin: 0 0 1.1rem;
    font-size: 1.15rem;
  }
  .featured-side dl {
    margin: 0 0 1.5rem;
  }
  .featured-side dt {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--gold-light);
    margin-top: 1rem;
  }
  .featured-side dt:first-child {
    margin-top: 0;
  }
  .featured-side dd {
    margin: 0.25rem 0 0;
    font-size: 0.93rem;
    color: #c3ccdb;
  }

  .callout .lead {
    margin: 0.6rem auto 1.6rem;
  }
  .center {
    text-align: center;
  }

  @media (max-width: 860px) {
    .featured {
      grid-template-columns: 1fr;
    }
    .featured-side {
      position: static;
    }
  }
</style>
