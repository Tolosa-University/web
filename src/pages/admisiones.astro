---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';

const pasos = [
  { n: '1', title: 'Solicitud', text: 'Escríbenos a info@tolosauniversity.com. A mano, si te apetece, aunque aceptamos teclado.' },
  { n: '2', title: 'Prueba de saberes', text: 'Una conversación distendida donde demuestras curiosidad. No hay tipo test: hay charla.' },
  { n: '3', title: 'Entrevista', text: 'Nos cuentas qué te gustaría saber y por qué. Las respuestas correctas nos importan menos que las buenas preguntas.' },
  { n: '4', title: 'Matrícula', text: 'Bienvenido a la última generación que lo sabrá todo por sí misma.' },
];

const requisitos = [
  'Curiosidad incurable y ganas de discutir con argumentos.',
  'Capacidad de leer un texto largo hasta el final. Sí, hasta el final.',
  'Disposición a recordar cosas sin apuntarlas en el móvil.',
  'Tolerancia a las sobremesas de más de dos horas.',
  'No es imprescindible saberlo todo al entrar. Al salir, sí.',
];

const calendario = [
  { fecha: 'Otoño', evento: 'Apertura del plazo de solicitud' },
  { fecha: 'Invierno', evento: 'Pruebas de saberes y entrevistas' },
  { fecha: 'Primavera', evento: 'Publicación de admitidos (en tablón de corcho)' },
  { fecha: 'Verano', evento: 'Matrícula y bienvenida' },
];
---

<Layout
  title="Admisiones — Tolosa University"
  description="Solicita plaza en Tolosa University. Proceso de admisión, requisitos y calendario para el curso 2025/2026. Únete a la universidad de los que to’ lo saben."
>
  <PageHero
    eyebrow="Admisiones · Curso 2025 / 2026"
    title="Solicita tu plaza en Tolosa"
    subtitle="El proceso es humano de principio a fin. Nos interesa cómo piensas, no cuánto memorizas para el examen de acceso."
  />

  <!-- PROCESO -->
  <section class="section">
    <div class="wrap">
      <div class="section-head center">
        <p class="eyebrow">Cómo entrar</p>
        <h2>Cuatro pasos, ninguna letra pequeña</h2>
      </div>
      <div class="grid grid-4">
        {pasos.map((p) => (
          <div class="step">
            <span class="step-n">{p.n}</span>
            <h3>{p.title}</h3>
            <p>{p.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- REQUISITOS + CALENDARIO -->
  <section class="section section--cream">
    <div class="wrap two-col">
      <div id="requisitos">
        <p class="eyebrow">Requisitos</p>
        <h2>Qué buscamos en ti</h2>
        <hr class="divider" />
        <ul class="req-list">
          {requisitos.map((r) => (
            <li>{r}</li>
          ))}
        </ul>
      </div>
      <div id="calendario">
        <p class="eyebrow">Calendario</p>
        <h2>Fechas clave</h2>
        <hr class="divider" />
        <table class="cal">
          <tbody>
            {calendario.map((c) => (
              <tr>
                <th scope="row">{c.fecha}</th>
                <td>{c.evento}</td>
              </tr>
            ))}
          </tbody>
        </table>
        <p class="cal-note">Sin fechas exactas: el conocimiento no entiende de relojes, pero avisamos con tiempo.</p>
      </div>
    </div>
  </section>

  <!-- CTA GENERADOR -->
  <section class="section">
    <div class="wrap center">
      <div class="section-head center">
        <p class="eyebrow">¿Con prisa?</p>
        <h2>Tu título, sin esperar al proceso</h2>
        <p>Mientras llega tu carta de admisión, genera tu propio diploma de Tolosa University.</p>
      </div>
      <a href="/generador/" class="btn btn-primary">Genera tu título</a>
    </div>
  </section>
</Layout>

<style>
  .step {
    text-align: center;
    padding: 1.5rem 1rem;
  }
  .step-n {
    display: grid;
    place-items: center;
    width: 52px;
    height: 52px;
    margin: 0 auto 1rem;
    border-radius: 50%;
    background: var(--navy);
    color: var(--gold-light);
    font-family: var(--font-serif);
    font-weight: 800;
    font-size: 1.35rem;
    border: 2px solid var(--gold);
  }
  .step h3 {
    margin: 0 0 0.5rem;
    font-size: 1.15rem;
  }
  .step p {
    margin: 0;
    color: var(--muted);
    font-size: 0.94rem;
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }
  .req-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }
  .req-list li {
    position: relative;
    padding-left: 1.8rem;
    color: var(--ink);
  }
  .req-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    top: 0;
    color: var(--gold-deep);
    font-weight: 800;
  }

  .cal {
    width: 100%;
    border-collapse: collapse;
  }
  .cal th,
  .cal td {
    text-align: left;
    padding: 0.85rem 0.5rem;
    border-bottom: 1px solid var(--line);
    vertical-align: top;
  }
  .cal th {
    width: 35%;
    color: var(--gold-deep);
    font-weight: 700;
  }
  .cal-note {
    font-size: 0.88rem;
    color: var(--muted);
    font-style: italic;
    margin-top: 1rem;
  }

  @media (max-width: 720px) {
    .two-col {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
