---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Tolosa University — La universidad de los que to’ lo saben',
  description = 'Tolosa University, la School of Pre-AI Omniscience. Grados, profesorado e investigación al servicio del saber humano. In Wikipedia Veritas.',
  ogImage = '/img/tolosauniversity-logo.jpeg',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollegeOrUniversity',
  name: 'Tolosa University',
  alternateName: 'La universidad de los que to’ lo saben',
  slogan: 'In Wikipedia Veritas',
  url: Astro.site?.href,
  logo: ogImageUrl,
  foundingDate: 'Pre-AI',
  description,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Tolosa',
    addressRegion: 'Gipuzkoa',
    addressCountry: 'ES',
  },
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#14243f" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Tolosa University" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href="/img/favicon.svg" />
    <link rel="icon" href="/img/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/img/favicon-16x16.png" type="image/png" sizes="16x16" />
    <link rel="icon" href="/img/favicon-32x32.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/img/apple-touch-icon.png" />
    <link rel="manifest" href="/img/site.webmanifest" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;0,800;1,500&family=Roboto+Slab:wght@600;700;800&family=Source+Sans+3:ital,wght@0,400;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />

    <slot name="head" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-94C41XE0MN"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-94C41XE0MN');
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Saltar al contenido</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  :root {
    --navy: #14243f;
    --navy-2: #1d3255;
    --navy-soft: #24406b;
    --gold: #c19a4b;
    --gold-light: #d9b869;
    --gold-deep: #a8823a;
    --cream: #f7f3ea;
    --paper: #fbf9f3;
    --ink: #21262f;
    --muted: #5c6675;
    --line: #e5ded0;

    --font-serif: 'Playfair Display', Georgia, 'Times New Roman', serif;
    --font-slab: 'Roboto Slab', Georgia, serif;
    --font-sans: 'Source Sans 3', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;

    --wrap: 74rem;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    scroll-padding-top: 5rem;
  }

  body {
    margin: 0;
    font-family: var(--font-sans);
    line-height: 1.65;
    color: var(--ink);
    background: var(--paper);
    padding-top: 4.7rem;
    -webkit-font-smoothing: antialiased;
  }

  h1,
  h2,
  h3 {
    font-family: var(--font-serif);
    line-height: 1.15;
    color: var(--navy);
    font-weight: 700;
  }

  a {
    color: var(--navy-soft);
  }

  img {
    max-width: 100%;
    height: auto;
  }

  .skip-link {
    position: absolute;
    left: -999px;
    top: 0;
    background: var(--gold);
    color: var(--navy);
    padding: 0.6rem 1rem;
    z-index: 100;
    border-radius: 0 0 4px 0;
    font-weight: 700;
  }
  .skip-link:focus {
    left: 0;
  }

  /* ---- Layout helpers shared across pages ---- */
  .wrap {
    width: 100%;
    max-width: var(--wrap);
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  .section {
    padding-block: 4.5rem;
  }

  .section--cream {
    background: var(--cream);
  }

  .section--navy {
    background: var(--navy);
    color: #e7ebf2;
  }
  .section--navy h1,
  .section--navy h2,
  .section--navy h3 {
    color: #fff;
  }

  .eyebrow {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold-deep);
    margin-bottom: 0.9rem;
  }
  .section--navy .eyebrow {
    color: var(--gold-light);
  }

  .section-head {
    max-width: 44rem;
    margin-bottom: 2.75rem;
  }
  .section-head.center {
    margin-inline: auto;
    text-align: center;
  }
  .section-head h2 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    margin: 0 0 0.9rem;
  }
  .section-head p {
    font-size: 1.08rem;
    color: var(--muted);
    margin: 0;
  }
  .section--navy .section-head p {
    color: #b9c2d2;
  }

  .lead {
    font-size: 1.2rem;
    color: var(--muted);
  }

  /* Botones */
  .btn {
    display: inline-block;
    font-weight: 700;
    text-decoration: none;
    padding: 0.8rem 1.6rem;
    border-radius: 5px;
    transition: transform 0.15s ease, background 0.15s ease, color 0.15s ease;
    font-size: 1rem;
  }
  .btn-primary {
    background: var(--gold);
    color: var(--navy);
  }
  .btn-primary:hover {
    background: var(--gold-light);
    transform: translateY(-2px);
  }
  .btn-ghost {
    border: 2px solid rgba(255, 255, 255, 0.5);
    color: #fff;
  }
  .btn-ghost:hover {
    border-color: var(--gold);
    color: var(--gold-light);
  }
  .btn-outline {
    border: 2px solid var(--navy);
    color: var(--navy);
  }
  .btn-outline:hover {
    background: var(--navy);
    color: #fff;
  }

  /* Rejilla de tarjetas */
  .grid {
    display: grid;
    gap: 1.5rem;
  }
  .grid-2 {
    grid-template-columns: repeat(2, 1fr);
  }
  .grid-3 {
    grid-template-columns: repeat(3, 1fr);
  }
  .grid-4 {
    grid-template-columns: repeat(4, 1fr);
  }

  .card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 1.75rem;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 14px 34px rgba(20, 36, 63, 0.1);
    border-color: var(--gold);
  }
  .card h3 {
    margin: 0.2rem 0 0.6rem;
    font-size: 1.25rem;
  }
  .card p {
    margin: 0;
    color: var(--muted);
    font-size: 0.97rem;
  }

  .divider {
    width: 60px;
    height: 3px;
    background: var(--gold);
    border: 0;
    margin: 1.25rem 0;
  }
  .center .divider {
    margin-inline: auto;
  }

  @media (max-width: 900px) {
    .grid-3,
    .grid-4 {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 620px) {
    .grid-2,
    .grid-3,
    .grid-4 {
      grid-template-columns: 1fr;
    }
    .section {
      padding-block: 3rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      scroll-behavior: auto !important;
      transition: none !important;
    }
  }
</style>
